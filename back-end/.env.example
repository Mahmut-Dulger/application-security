DATABASE_URL="postgresql://USERNAME:PASSWORD@localhost:5432/travel_booking"

# Long random secret.,  with: openssl rand -hex 32
JWT_SECRET="<replace>"


JWT_EXPIRES_HOURS=8


APP_PORT=3000


ALLOWED_ORIGINS="http://localhost:8200"


FRONTEND_URL="http://localhost:8200"

# Defaults below match the MailHog container in docker-compose.yml.
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_SECURE="false"           
SMTP_USER="test"              # any value works for MailHog
SMTP_PASS="test"              # any value works for MailHog
SMTP_FROM="noreply@example.com"
